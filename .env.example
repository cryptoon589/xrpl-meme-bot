# XRPL Meme Bot — Environment Configuration
# Copy to .env and fill in your values

# ── XRPL Connection ────────────────────────────────────────────────
XRPL_WS_URL=wss://rpc.xrplclaw.com/ws

# ── Telegram Bot ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Comma-separated extra chat IDs that receive alerts (primary is always included)
ALLOWED_CHAT_IDS=

# ── Operating Mode ─────────────────────────────────────────────────
# WATCH = scan and alert only | PAPER = simulate trades with tracked PnL
MODE=PAPER

# ── Risk / Entry Gates ─────────────────────────────────────────────
MIN_LIQUIDITY_XRP=2000          # Minimum AMM pool depth to consider a token
MIN_SCORE_ALERT=60              # Score threshold for WATCH-mode alerts (unused in PAPER)
MIN_SCORE_PAPER_TRADE=80        # Score threshold to open a paper trade

# ── Paper Trading ──────────────────────────────────────────────────
STARTING_BANKROLL_XRP=500       # Simulated starting balance
MIN_TRADE_XRP=5                 # Minimum position size
MAX_TRADE_XRP=20                # Maximum position size (before conviction multiplier)
MAX_OPEN_TRADES=3               # Max concurrent open positions
MAX_DAILY_LOSS_XRP=50           # Daily loss limit — bot pauses trading if hit

# ── Live / Auto-Execution (leave blank to disable) ──────────────────
# Generate with: node -e "const x=require('xrpl');const w=x.Wallet.generate();console.log(w.address,w.seed)"
TRADING_WALLET_SEED=
LIVE_TRADING=false

# ── Internals ──────────────────────────────────────────────────────
CONFIG_PATH=./bot-config.json   # Path to auto-apply recommendations JSON
HEALTH_PORT=3000                # HTTP health endpoint port (/health, /healthz)
MAX_TX_QUEUE_SIZE=500           # Max queued XRPL transactions awaiting scoring

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=info                  # debug | info | warn | error
