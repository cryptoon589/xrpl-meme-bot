# XRPL Meme Bot — Environment Configuration
# Copy to .env and fill in your values

# ── XRPL Connection ────────────────────────────────────────────────
XRPL_WS_URL=wss://rpc.xrplclaw.com/ws

# ── Telegram Bot ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Operating Mode ─────────────────────────────────────────────────
# WATCH = scan and alert only | PAPER = simulate trades with tracked PnL
MODE=PAPER

# ── Risk / Entry Gates ─────────────────────────────────────────────
MIN_LIQUIDITY_XRP=500           # Minimum AMM pool depth (500 catches new launches)
MIN_SCORE_ALERT=50              # Score threshold for alert-only (WATCH mode)
MIN_SCORE_PAPER_TRADE=55        # Score threshold to open a paper trade

# ── Paper Trading ──────────────────────────────────────────────────
STARTING_BANKROLL_XRP=500       # Simulated starting balance
MIN_TRADE_XRP=5                 # Minimum position size
MAX_TRADE_XRP=20                # Maximum position size (burst trades cap at 25 XRP)
MAX_OPEN_TRADES=3               # Max concurrent open positions
MAX_DAILY_LOSS_XRP=50           # Daily loss limit — bot pauses if hit

# ── Live / Auto-Execution (leave blank for paper-only) ─────────────
TRADING_WALLET_SEED=            # Your XRPL wallet seed (r... address)
LIVE_TRADING=false              # Set true only when TRADING_WALLET_SEED is set

# ── Internals ──────────────────────────────────────────────────────
HEALTH_PORT=3000                # HTTP health endpoint port (/health, /healthz)
LOG_LEVEL=info                  # debug | info | warn | error
