# XRPL Meme Bot Configuration

# XRPL Connection
XRPL_WS_URL=wss://rpc.xrplclaw.com/ws

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# Comma-separated list of chat IDs allowed to receive alerts (whitelist).
# Primary TELEGRAM_CHAT_ID is always included automatically.
# Default whitelist includes 5023314955.
ALLOWED_CHAT_IDS=5023314955

# Operating Mode: WATCH or PAPER (AUTO is stub-only)
MODE=WATCH

# Risk Thresholds
MIN_LIQUIDITY_XRP=2000
MIN_SCORE_ALERT=60
MIN_SCORE_PAPER_TRADE=80

# Paper Trading Config
STARTING_BANKROLL_XRP=500
MAX_TRADE_XRP=20
MAX_OPEN_TRADES=3
MAX_DAILY_LOSS_XRP=50

# Scoring Weights (should sum to 100)
WEIGHT_LIQUIDITY=20
WEIGHT_HOLDER_GROWTH=15
WEIGHT_BUY_PRESSURE=20
WEIGHT_VOLUME_ACCEL=15
WEIGHT_DEV_SAFETY=15
WEIGHT_WHITELIST_BOOST=10
WEIGHT_SPREAD=5

# Auto-Execution (leave blank to disable)
# Generate wallet with: node -e "const x=require('xrpl');const w=x.Wallet.generate();console.log(w.address,w.seed)"
TRADING_WALLET_SEED=
LIVE_TRADING=false

# Transaction Queue
MAX_TX_QUEUE_SIZE=500

# Logging
LOG_LEVEL=info
